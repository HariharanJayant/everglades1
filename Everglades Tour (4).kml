	<Placemark id="5C3BDEEDBB000001">
		<name>Bridgeland Highschool</name>
		<description><![CDATA[<div><span style="color: rgb(31, 31, 31); font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: start; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; white-space: normal; background-color: rgb(255, 255, 255); text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial; float: none; display: inline;"><span class="font" style="font-family: &quot;Google Sans&quot;, Roboto, Arial, sans-serif;"><span class="size" style="font-size: 16px;">Bridgeland High School is a high school in the Bridgeland community in unincorporated Harris County, Texas, in the Houston metropolitan area.</span></span></span><br></div>]]></description>
		<LookAt>
